{
  "name": "pebble",
  "private": true,
  "version": "0.0.11",
  "packageManager": "pnpm@11.1.1",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "build:frontend": "tsc && vite build",
    "preview": "vite preview",
