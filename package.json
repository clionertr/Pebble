    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/extension-placeholder": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "@types/turndown": "^5.0.6",
    "dompurify": "^3.4.1",
    "i18next": "^26.0.3",
    "lucide-react": "^0.500.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.2",
    "tiptap-markdown": "^0.9.0",
    "turndown": "^7.2.4",
    "zustand": "^5.0.0"
