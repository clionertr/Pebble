# ── Auth (REQUIRED) ─────────────────────────────────────────────────────
# Generate a bcrypt hash for your password:
#   cargo install bcrypt-cli && bcrypt-cli hash 'your-password'
# Or: python3 -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt(rounds=12)).decode())"
#
# IMPORTANT for Docker Compose: The $ signs in bcrypt hashes must be
# escaped as $$ in the .env file. Otherwise Docker Compose will try to
# interpret them as variables and strip them out.
#   Example for Docker: PEBBLE_PASSWORD_HASH=$$2b$$12$$...
#   Example for direct run: PEBBLE_PASSWORD_HASH='$2b$12$...' (with quotes)
PEBBLE_PASSWORD_HASH=your-bcrypt-hash-here

# ── Google OAuth (required for Gmail) ───────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a "Web application" OAuth client
# 3. Add https://<your-domain>/auth/callback as authorized redirect URI
#    (or http://localhost:3000/auth/callback for local dev)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Microsoft OAuth (required for Outlook) ─────────────────────────────
# 1. Go to https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/
# 2. Register as a public/native app with redirect URI http://localhost
# 3. No client secret needed for public/native apps.
MICROSOFT_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CLIENT_SECRET=  (leave empty for public/native apps)

# ── Gmail Real-time Push (optional) ────────────────────────────────────
# Create a Pub/Sub topic and push subscription at:
# https://<your-host>/webhook/gmail?secret=<same-secret>
# GMAIL_PUBSUB_TOPIC=projects/your-project-id/topics/gmail-webmail-topic
# GMAIL_WEBHOOK_SECRET=replace-with-a-long-random-secret

# ── Server ──────────────────────────────────────────────────────────────
# PEBBLE_HOST=127.0.0.1
# PEBBLE_PORT=3000

# ── Deployment ─────────────────────────────────────────────────────────
# Full URL where /auth/callback is accessible (for OAuth redirect).
# Default: http://localhost:3000
# OAUTH_REDIRECT_URL=https://your-domain.com

# CORS allowed origin (same-origin by default).
# Set to your frontend URL only if frontend & backend are on different origins.
# ALLOWED_ORIGIN=
