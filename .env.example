# Google OAuth credentials (required for Gmail support)
# Create a "Desktop app" OAuth client at https://console.cloud.google.com/apis/credentials
# Some Google Desktop OAuth clients require the generated client secret during token exchange.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Optional: set this if Google returns "client_secret is missing" during login.
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Gmail API watch + Pub/Sub realtime push.
# Create a Pub/Sub topic and point a push subscription at:
# https://<your-host>/webhook/gmail?secret=<same-secret>
# GMAIL_PUBSUB_TOPIC=projects/your-project-id/topics/gmail-webmail-topic
# GMAIL_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Microsoft OAuth credentials (required for Outlook support)
# Register as a public/native client with redirect URI http://localhost.
# No client secret needed. Pebble uses PKCE public client flow.
MICROSOFT_CLIENT_ID=your-microsoft-client-id
# Optional: only for confidential/web app registrations. Public/native clients should leave this unset.
# MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Server configuration
# PEBBLE_HOST=127.0.0.1
# PEBBLE_PORT=3000
